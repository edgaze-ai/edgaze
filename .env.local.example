# Edgaze Environment Variables

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SUPABASE_PROJECT_ID=your_project_id

# Analytics
NEXT_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token
NEXT_PUBLIC_MIXPANEL_RECORD_PERCENT=100

# Performance optimizations
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_PRELOAD=true

# Workflow execution v2 (see src/server/flow-v2/)
# WORKFLOW_EXECUTION_V2_COMPILE=true
# WORKFLOW_EXECUTION_V2_RUNNER=true
# WORKFLOW_ENGINE_PERF_LOG=1
