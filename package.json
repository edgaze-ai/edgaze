{
  "name": "edgaze-prod",
  "version": "1.2.3",
  "description": "Create, sell, and distribute AI products. A curated marketplace for prompts and workflows. [Proprietary]",
  "private": true,
  "type": "module",
  "author": "Edge Platforms, Inc.",
  "license": "UNLICENSED",
  "keywords": [
    "ai",
    "prompts",
    "workflows",
    "marketplace",
    "nextjs",
    "typescript",
    "supabase"
  ],
  "scripts": {
    "dev": "node scripts/dev-singleton.mjs",
    "dev:clean": "rm -rf .next && node scripts/dev-singleton.mjs",
    "dev:turbo": "next dev --turbopack",
    "build": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && env CI=true next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "clean": "rm -rf .next node_modules",
    "reinstall": "npm run clean && npm install",
    "ci:install": "node scripts/run-npm-clean.mjs ci",
    "ci:build": "node scripts/run-npm-clean.mjs run build",
    "gemini:list-models": "node scripts/list-gemini-models.mjs",
    "db:types": "npx supabase gen types typescript --project-id $NEXT_PUBLIC_SUPABASE_PROJECT_ID > src/types/supabase.ts",
    "db:push": "npx supabase db push",
    "db:reset": "npx supabase db reset",
    "postinstall": "node scripts/copy-pdf-worker.mjs",
    "og:generate": "node scripts/generate-og.mjs",
    "favicon:generate": "node scripts/generate-favicon-ico.mjs"
  },
  "dependencies": {
    "@stripe/connect-js": "^3.3.34",
    "@stripe/react-connect-js": "^3.3.33",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.9.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.84.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/lodash.debounce": "^4.0.9",
    "@vercel/analytics": "^1.6.1",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^0.452.0",
    "mixpanel-browser": "^2.73.0",
    "next": "^16.0.1",
    "next-auth": "^4.24.13",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.7",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "react-resizable-panels": "^3.0.6",
    "reactflow": "^11.11.4",
    "recharts": "^2.15.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^20.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20.14.12",
    "@types/pdfkit": "^0.17.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "enhanced-resolve": "^5.20.1",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.1.1",
    "postcss": "^8.4.45",
    "prettier": "^3.3.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "to-ico": "1.0.1",
    "typescript": "^5.6.2",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}
