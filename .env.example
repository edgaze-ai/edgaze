# ============================================
# Edgaze Environment Configuration
# ============================================
#
# Copy this file to .env.local and fill in your values.
# DO NOT commit .env.local to version control.
#

# ============================================
# Application
# ============================================

# Base URL for the application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Canonical public site URL (metadata / Open Graph). Production example: https://www.edgaze.ai
# NEXT_PUBLIC_SITE_URL=https://www.edgaze.ai

# ============================================
# Supabase
# ============================================

# Supabase project URL
# Find at: https://app.supabase.com/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key (public, client-side)
# Find at: https://app.supabase.com/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (secret, server-side only)
# ⚠️ KEEP THIS SECRET - Never expose in client code
# Find at: https://app.supabase.com/project/YOUR_PROJECT/settings/api
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# AES-256 master key for user BYO API secrets (32 bytes, base64). Generate: openssl rand -base64 32
USER_API_KEY_VAULT_KEY=

# ============================================
# Authentication (NextAuth)
# ============================================

# NextAuth configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here

# Generate secret with: openssl rand -base64 32

# ============================================
# OAuth Providers
# ============================================

# Google OAuth
# Get credentials: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook Login (optional). FACEBOOK_CLIENT_ID is also emitted as fb:app_id for link previews.
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# FACEBOOK_APP_ID=

# Optional: Additional OAuth providers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ============================================
# Analytics
# ============================================

# Mixpanel (optional)
# Get token: https://mixpanel.com/
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token
# Session replay sample rate 0–100 (defaults: 100 in production, 0 in dev). Requires Session Replay on your Mixpanel plan.
NEXT_PUBLIC_MIXPANEL_RECORD_PERCENT=100

# Vercel Analytics (automatically enabled on Vercel)

# ============================================
# Storage & Assets
# ============================================

# Supabase Storage bucket name
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=assets

# Maximum upload size (bytes)
# Default: 5MB
MAX_UPLOAD_SIZE=5242880

# ============================================
# Rate Limiting
# ============================================

# Workflow run limits
DEFAULT_RUN_LIMIT=10
PREMIUM_RUN_LIMIT=100

# API rate limits (requests per minute)
ANONYMOUS_RATE_LIMIT=10
AUTHENTICATED_RATE_LIMIT=100

# ============================================
# Feature Flags
# ============================================

# Enable/disable features
ENABLE_PAYMENTS=false
ENABLE_WEBHOOKS=false
ENABLE_API_ACCESS=false

# Maintenance mode
MAINTENANCE_MODE=false

# ============================================
# Email (Optional)
# ============================================

# SMTP configuration for transactional emails
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password
# SMTP_FROM=noreply@edgaze.com

# Welcome emails (configured in Supabase Edge Function secrets, not here):
# - RESEND_API_KEY: required for send-welcome-email function
# - RESEND_FROM_EMAIL: optional, default EdGaze <onboarding@edgaze.ai>
# - EDGAZE_APP_URL: optional, default https://edgaze.ai
# See docs/WELCOME_EMAIL_SETUP.md

# ============================================
# Monitoring & Logging
# ============================================

# Sentry (optional)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# Log level (error | warn | info | debug)
LOG_LEVEL=info

# ============================================
# Development
# ============================================

# Enable debug mode
DEBUG=false

# Enable verbose logging
VERBOSE_LOGGING=false

# Disable telemetry
NEXT_TELEMETRY_DISABLED=1

# ============================================
# Production
# ============================================

# Environment
NODE_ENV=development

# Enable source maps in production (optional)
# GENERATE_SOURCEMAP=true

# ============================================
# Platform LLM keys (optional)
# ============================================
# Used for Edgaze-funded workflow runs when creators do not supply their own keys.
# OpenAI: https://platform.openai.com/api-keys
# EDGAZE_OPENAI_API_KEY=
# Anthropic (Claude): https://console.anthropic.com/
# EDGAZE_ANTHROPIC_API_KEY=
# Google Gemini (AI Studio): https://aistudio.google.com/apikey
# EDGAZE_GEMINI_API_KEY=

# ============================================
# External Services (Optional)
# ============================================

# Stripe (for payments) – set from environment; never commit real keys
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Webhooks
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=

# Stripe Connect
# Get from: https://dashboard.stripe.com/settings/applications
STRIPE_CONNECT_CLIENT_ID=

# Stripe Configuration
STRIPE_PLATFORM_FEE_PERCENTAGE=20
STRIPE_MINIMUM_PAYOUT_CENTS=1000

# Platform subscription price (create in Stripe Dashboard)
# Required for subscription checkout with customer_account
STRIPE_PLATFORM_PRICE_ID=

# Thin events webhook secret (for V2 account requirement updates)
# Use a separate event destination in Stripe Dashboard with thin payload style
STRIPE_THIN_WEBHOOK_SECRET=

# Cron Job Secret (generate with: openssl rand -base64 32)
CRON_SECRET=your-cron-secret-here

# Upstash Redis (for caching - optional)
# UPSTASH_REDIS_URL=
# UPSTASH_REDIS_TOKEN=

# ============================================
# Notes
# ============================================
#
# Required variables:
# - NEXT_PUBLIC_APP_URL
# - NEXT_PUBLIC_SUPABASE_URL
# - NEXT_PUBLIC_SUPABASE_ANON_KEY
# - SUPABASE_SERVICE_ROLE_KEY
# - NEXTAUTH_URL
# - NEXTAUTH_SECRET
#
# Optional but recommended:
# - GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET (for Google OAuth)
# - NEXT_PUBLIC_MIXPANEL_TOKEN (for analytics)
#
# Security reminders:
# - Never commit .env.local
# - Rotate keys regularly
# - Use different keys for dev/staging/prod
# - Keep service role key secure
#
